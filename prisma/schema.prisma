generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(EDITOR)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  EDITOR
}

model SiteSettings {
  id            String   @id @default("default")
  title         String   @default("Jebaz Wesley Raj")
  subtitle      String   @default("Full Stack Developer")
  description   String   @default("Premium portfolio website")
  keywords      String   @default("portfolio, developer, full stack")
  profileImage  String?
  resumeUrl     String?
  heroTitle     String   @default("Jebaz Wesley Raj")
  heroSubtitle  String   @default("Full Stack Developer & Creative Technologist")
  heroBackground String?
  aboutTitle    String   @default("About Me")
  aboutBio      String   @default("")
  aboutEducation String  @default("")
  aboutGoals    String   @default("")
  githubUrl     String?
  linkedinUrl   String?
  twitterUrl    String?
  email         String?
  phone         String?
  location      String?
  primaryColor  String   @default("#D4AF37")
  updatedAt     DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String?
  challenges  String?
  technologies String[]
  githubUrl   String?
  demoUrl     String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  images      ProjectImage[]
}

model ProjectImage {
  id        String @id @default(cuid())
  url       String
  alt       String?
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  order     Int     @default(0)
}

model SkillCategory {
  id       String  @id @default(cuid())
  name     String
  order    Int     @default(0)
  skills   Skill[]
}

model Skill {
  id         String        @id @default(cuid())
  name       String
  level      Int           @default(50)
  icon       String?
  categoryId String
  category   SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  order      Int           @default(0)
}

model Experience {
  id          String   @id @default(cuid())
  company     String
  role        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean  @default(false)
  type        String   @default("work")
  location    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Certification {
  id               String @id @default(cuid())
  title            String
  issuer           String
  description      String?
  imageUrl         String?
  pdfUrl           String?
  verificationUrl  String?
  issueDate        DateTime?
  expiryDate       DateTime?
  order            Int    @default(0)
  createdAt        DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Analytics {
  id        String   @id @default(cuid())
  page      String
  visits    Int      @default(1)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}
